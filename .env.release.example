# Release/CI configuration example.
# Do not copy this to .env for normal runtime usage. Configure these as CI secrets or local shell env.

# --- npm CLI publish ---
NPM_TOKEN=

# --- Release manifest signing ---
# Prefer CI secret ZLEAP_MANIFEST_PRIVATE_KEY containing a base64 or PEM PKCS8 RSA private key for RSA-SHA256.
ZLEAP_MANIFEST_PRIVATE_KEY=
# Local-only alternative:
# ZLEAP_MANIFEST_PRIVATE_KEY_PATH=
# Public key used by install smoke or private deployment verification:
# ZLEAP_MANIFEST_PUBLIC_KEY=
# Public key is normally committed in distribution.json updater.manifestPublicKey.

# --- Tauri updater ---
# The public minisign key is committed in tauri.conf.json (plugins.updater.pubkey); CI never injects it.
# Only the signing private key + password are secrets, consumed by tauri-action.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# --- Optional distribution URL overrides ---
# Leave empty for distribution.json defaults. Useful for private release dry-runs or CDN migration tests.
# ZLEAP_RELEASE_BASE=
# install-manifest.json (runtime/payload contract) consumed by install.sh / install.ps1 / host upgrade:
# ZLEAP_INSTALL_MANIFEST_URL=
# latest.json (Tauri desktop updater manifest):
# ZLEAP_UPDATER_MANIFEST_URL=
# ZLEAP_MANIFEST_URL=

# --- macOS signing / notarization ---
APPLE_CERTIFICATE_BASE64=
APPLE_CERTIFICATE_PASSWORD=
APPLE_SIGNING_IDENTITY=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# --- Windows signing ---
# Optional for v0.1 public release. If omitted, win-x64 assets are built and uploaded unsigned.
WINDOWS_CERTIFICATE_BASE64=
WINDOWS_CERTIFICATE_PASSWORD=

# --- Runtime dependency bundling ---
# package:node downloads pinned official Node.js archives from distribution.json runtime.node.sources.
ZLEAP_NODE_BUNDLE=
ZLEAP_NODE_BUNDLE_SHA256=
ZLEAP_NODE_SOURCE_CACHE=
# package:postgres builds from official PostgreSQL + pgvector source.
# package:release consumes explicit bundles; it does not discover local/system Node/Postgres.
ZLEAP_POSTGRES_BUNDLE=
ZLEAP_POSTGRES_BUNDLE_SHA256=
# Optional local caches for package:postgres.
ZLEAP_POSTGRES_SOURCE_CACHE=
ZLEAP_POSTGRES_BUILD_DIR=
# Optional local explicit staging root. Strict release must build from declared sources instead.
ZLEAP_POSTGRES_STAGED_ROOT=

# --- Release completeness gates ---
# Expected platforms default to the official matrix (mac-arm64, win-x64). These optional
# overrides are only needed to validate a non-default platform set.
# ZLEAP_EXPECT_RUNTIME_PLATFORMS=mac-arm64,win-x64
# ZLEAP_EXPECT_PAYLOAD_PLATFORMS=mac-arm64,win-x64
