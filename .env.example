# Copy to ~/.zleap/.env for local runtime overrides, or to .env.local for development.
# Normal users should prefer Web onboarding instead of editing this file.

# --- LLM (required before chatting) ---
ZLEAP_MODEL_BASE_URL=https://api.example.com/v1
ZLEAP_MODEL_API_KEY=
ZLEAP_MODEL_NAME=

# --- Database (optional — bundled Postgres on port 5433 when using release install) ---
# ZLEAP_DATABASE_URL=postgres://zleap:zleap@127.0.0.1:5433/zleap

# --- Embeddings (optional — faux embeddings used when unset) ---
# ZLEAP_EMBED_MODEL=
# ZLEAP_EMBED_BASE_URL=
# ZLEAP_EMBED_API_KEY=
# ZLEAP_EMBED_DIM=1536

# --- Local serve (set automatically by install.sh / desktop app) ---
# ZLEAP_WEB_PORT=3000
# ZLEAP_SERVE_MODE=production
# ZLEAP_GATEWAY=1
# ZLEAP_AUTH_MODE=localhost

# --- Remote / trusted auth (non-localhost deployments) ---
# ZLEAP_AUTH_MODE=trusted-header
# ZLEAP_TRUSTED_ACTOR_HEADER_SECRET=

# --- IM Gateway (optional) ---
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_DOMAIN=feishu
# FEISHU_CLI_ENABLED=false
# WECHAT_ENABLED=false
# WECHAT_BASE_URL=

# --- Paths ---
# ZLEAP_HOME=~/.zleap
# ZLEAP_FILE_WORKSPACE_ROOT=
# ZLEAP_WEB_SKILLS_ROOT=
