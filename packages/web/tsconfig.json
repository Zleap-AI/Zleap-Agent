{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    // Pin React types to this package's own @types/react@19. The monorepo also
    // has @types/react@18 (the Ink CLI), which pnpm hoists to the root; without
    // these paths tsc resolves the inferred JSX return types against the 18.x
    // copy and fails with TS2742 ("cannot be named … @types+react@18.3.30").
    "paths": {
      "@/*": ["./*"],
      "react": ["./node_modules/@types/react"],
      "react/*": ["./node_modules/@types/react/*"],
      "react-dom": ["./node_modules/@types/react-dom"],
      "react-dom/*": ["./node_modules/@types/react-dom/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}

