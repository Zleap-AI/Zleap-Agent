{
  "name": "@zleap/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\" && next build",
    "check": "node ../../scripts/check-web-design-tokens.mjs && tsc -p tsconfig.json --noEmit",
    "check:design": "node ../../scripts/check-web-design-tokens.mjs",
    "dev": "node ../../scripts/dev-web.mjs",
    "dev:next": "next dev",
    "start": "next start",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@iconify-json/vscode-icons": "^1.2.63",
    "@iconify/react": "^6.0.2",
    "@zleap/agent": "workspace:*",
    "@zleap/ai": "workspace:*",
    "@zleap/avatar": "workspace:*",
    "@zleap/core": "workspace:*",
    "@zleap/host": "workspace:*",
    "@zleap/store": "workspace:*",
    "@zleap/tasks": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-arborist": "^3.10.5",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0"
  }
}
